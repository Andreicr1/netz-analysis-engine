# ══════════════════════════════════════════════════════════════════
# Netz Analysis Engine — Environment Variables
# Stack: Timescale Cloud + Railway + Upstash Redis + OpenAI
# ══════════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────────
# Production: Timescale Cloud connection string
# Dev: docker-compose (postgresql+asyncpg://netz:password@localhost:5434/netz_engine)
DATABASE_URL=postgresql+asyncpg://netz:password@localhost:5434/netz_engine
DATABASE_URL_SYNC=postgresql+psycopg://netz:password@localhost:5434/netz_engine
# Production: Upstash Redis URL
# Dev: local Redis from docker-compose
REDIS_URL=redis://localhost:6379/0
APP_ENV=development

# ── Auth (Clerk) ───────────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_PUBLISHABLE_KEY=

# ── Dev bypass ────────────────────────────────────────────────────
DEV_ACTOR_HEADER=X-DEV-ACTOR
DEV_TOKEN=dev-token-change-me
# UUID da org de desenvolvimento — obrigatório para queries org-scoped em dev
DEV_ORG_ID=

# ── AI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ── OCR ───────────────────────────────────────────────────────────
MISTRAL_API_KEY=

# ── External APIs ─────────────────────────────────────────────────
FRED_API_KEY=
DC_API_KEY=
OPENFIGI_API_KEY=

# ── SEC EDGAR Bulk ────────────────────────────────────────────────
# local path to SEC Company Facts bulk JSON; dev-only until follow-up PR wires HTTP delta ingestion.
COMPANYFACTS_DIR=

# ── FE fundinfo (production fund data provider) ─────────────
FEATURE_FEFUNDINFO_ENABLED=false
FEFUNDINFO_CLIENT_ID=
FEFUNDINFO_CLIENT_SECRET=
FEFUNDINFO_SUBSCRIPTION_KEY=

# ── SEC EDGAR (public identifier — required by SEC policy) ────────
EDGAR_IDENTITY="Netz Analysis Engine tech@netzco.com"

# ── Storage ───────────────────────────────────────────────────────
# Priority: R2 > ADLS > LocalStorage
# Dev: LocalStorageClient (filesystem at .data/lake/)
# Prod: R2StorageClient (Cloudflare R2, S3-compatible)
# LOCAL_STORAGE_ROOT=.data/lake  # default, override for persistent volume path

# ── Cloudflare R2 (production — Milestone 2.5+) ──────────────────
FEATURE_R2_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=netz-data-lake
# R2_ENDPOINT_URL=  # auto-derived from R2_ACCOUNT_ID if empty

# ── ADLS (deprecated — kept for rollback) ────────────────────────
FEATURE_ADLS_ENABLED=false

# ── Optional: EDGAR ───────────────────────────────────────────────
# EDGAR_USER_AGENT=CompanyName email@example.com

# ══════════════════════════════════════════════════════════════════
# LOCAL DEV PROVIDERS (Legion / Z13 — zero API cost)
# Requires LM Studio + Ollama running locally.
# NEVER set these to true in production.
# ══════════════════════════════════════════════════════════════════

# ── Local LLM via LM Studio (porta 1234) ──────────────────────────
# USE_LOCAL_LLM=false
# LOCAL_LLM_URL=http://localhost:1234/v1

# ── Model overrides por stage (model_config.py le automaticamente) ─
# Descomente para rotear o pipeline inteiro pelo modelo local:
# NETZ_MODEL_CH01_EXEC=qwen3-14b
# NETZ_MODEL_CH02_MACRO=qwen3-14b
# NETZ_MODEL_CH03_EXIT=qwen3-14b
# NETZ_MODEL_CH04_SPONSOR=qwen3-14b
# NETZ_MODEL_CH05_LEGAL=qwen3-14b
# NETZ_MODEL_CH06_TERMS=qwen3-14b
# NETZ_MODEL_CH07_CAPITAL=qwen3-14b
# NETZ_MODEL_CH08_RETURNS=qwen3-14b
# NETZ_MODEL_CH09_DOWNSIDE=qwen3-14b
# NETZ_MODEL_CH10_COVENANTS=qwen3-14b
# NETZ_MODEL_CH11_RISKS=qwen3-14b
# NETZ_MODEL_CH12_PEERS=qwen3-14b
# NETZ_MODEL_CH13_RECOMMENDATION=qwen3-14b
# NETZ_MODEL_CH14_GOVERNANCE_STRESS=qwen3-14b
# NETZ_MODEL_CRITIC=qwen3-14b
# NETZ_MODEL_CRITIC_ESCALATION=phi-4-reasoning-plus
# NETZ_MODEL_STRUCTURED=qwen3-14b
# NETZ_MODEL_POLICY=qwen3-14b
# NETZ_MODEL_SPONSOR=qwen3-14b
# NETZ_MODEL_MEMO=qwen3-14b
# NETZ_MODEL_TONE_PASS1=qwen3-14b
# NETZ_MODEL_TONE_PASS2=qwen3-14b
# NETZ_MODEL_EXTRACTION=qwen3-14b
# NETZ_MODEL_DOC_REVIEW=qwen3-14b
# Benchmark Legion (2026-03-18): qwen3-14b=33.8 tok/s | phi-4-reasoning=32.6 tok/s

# ── Local Embeddings via Ollama ────────────────────────────────────
# USE_LOCAL_EMBEDDINGS=false
# LOCAL_EMBEDDING_MODEL=nomic-embed-text   # ~500MB VRAM, 768 dims
# LOCAL_EMBEDDING_URL=http://localhost:11434
# LOCAL_EMBEDDING_DIMENSIONS=768
# NOTA: 768 dims vs 3072 (OpenAI). Rodar make migrate ao trocar.
#       Nunca misturar embeddings de modelos diferentes no mesmo indice.

# ── Local OCR ─────────────────────────────────────────────────────
# USE_LOCAL_OCR=false
# LOCAL_OCR_PROVIDER=pymupdf   # pymupdf=PDFs nativos | qwen2vl=PDFs escaneados
# LOCAL_VLM_MODEL=olmocr       # modelo usado quando LOCAL_OCR_PROVIDER=local_vlm

# ══════════════════════════════════════════════════════════════════
# DEPRECATED — Azure services (kept for rollback only, 2026-03-18)
# These vars are accepted by settings.py but not required.
# All Azure services have been replaced by the Milestone 2 stack.
# Remove from production deployments when rollback is no longer needed.
# ══════════════════════════════════════════════════════════════════
# AZURE_OPENAI_ENDPOINT=        # replaced by OpenAI direct + retry
# AZURE_OPENAI_KEY=
# AZURE_SEARCH_ENDPOINT=        # replaced by pgvector (commit 497df51)
# AZURE_SEARCH_KEY=
# SEARCH_INDEX_NAME=
# SEARCH_CHUNKS_INDEX_NAME=
# KEYVAULT_URL=                 # replaced by platform env vars (Railway secrets)
# SERVICE_BUS_NAMESPACE=        # replaced by Redis pub/sub + BackgroundTasks
# APPLICATIONINSIGHTS_CONNECTION_STRING=  # replaced by structlog → stdout
# ADLS_ACCOUNT_NAME=            # replaced by LocalStorageClient + persistent volume
# ADLS_ACCOUNT_KEY=
# ADLS_CONTAINER_NAME=
# ADLS_CONNECTION_STRING=

# ══════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ══════════════════════════════════════════════════════════════════
FEATURE_WEALTH_CONTENT=false        # Habilita rota /content (flash reports, spotlights)
FEATURE_WEALTH_FACT_SHEETS=true     # Fact sheets (estável)
FEATURE_WEALTH_MONITORING=false     # Monitoring engine (beta)
FEATURE_AUTO_REBALANCE=false        # Rebalanceamento automático (experimental)

# ══════════════════════════════════════════════════════════════════
# TUNNING DE RUNTIME
# ══════════════════════════════════════════════════════════════════
# Slots de concorrência para chamadas LLM paralelas no deep_review
NETZ_LLM_CONCURRENCY=5
# Threshold de confiança local para escalada ao OpenAI (0.0 = nunca escala)
LOCAL_CONFIDENCE_THRESHOLD=0.0
