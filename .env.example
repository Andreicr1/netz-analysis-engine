# ══════════════════════════════════════════════════════════════════
# Netz Analysis Engine — Environment Variables
# Stack: Timescale Cloud + Railway + Upstash Redis + OpenAI
# ══════════════════════════════════════════════════════════════════

# ── Core ──────────────────────────────────────────────────────────
# Production: Timescale Cloud connection string
# Dev: docker-compose (postgresql+asyncpg://netz:password@localhost:5434/netz_engine)
DATABASE_URL=postgresql+asyncpg://netz:password@localhost:5434/netz_engine
DATABASE_URL_SYNC=postgresql+psycopg://netz:password@localhost:5434/netz_engine
# Production: Upstash Redis URL
# Dev: local Redis from docker-compose
REDIS_URL=redis://localhost:6379/0
APP_ENV=development

# ── Auth (Clerk) ───────────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_PUBLISHABLE_KEY=

# ── Dev bypass ────────────────────────────────────────────────────
DEV_ACTOR_HEADER=X-DEV-ACTOR
DEV_TOKEN=dev-token-change-me

# ── AI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ── OCR ───────────────────────────────────────────────────────────
MISTRAL_API_KEY=

# ── External APIs ─────────────────────────────────────────────────
FRED_API_KEY=

# ── SEC EDGAR (public identifier — required by SEC policy) ────────
EDGAR_IDENTITY="Netz Analysis Engine tech@netzco.com"

# ── Storage ───────────────────────────────────────────────────────
# false = LocalStorageClient (filesystem). Default for dev and Milestone 2 prod.
# true = ADLSStorageClient (Azure Blob). Enable at Milestone 3 when data lake > 100GB.
FEATURE_ADLS_ENABLED=false
# LOCAL_STORAGE_ROOT=.data/lake  # default, override for persistent volume path in prod

# ── Optional: EDGAR ───────────────────────────────────────────────
# EDGAR_USER_AGENT=CompanyName email@example.com

# ══════════════════════════════════════════════════════════════════
# DEPRECATED — Azure services (kept for rollback only, 2026-03-18)
# These vars are accepted by settings.py but not required.
# All Azure services have been replaced by the Milestone 2 stack.
# Remove from production deployments when rollback is no longer needed.
# ══════════════════════════════════════════════════════════════════
# AZURE_OPENAI_ENDPOINT=        # replaced by OpenAI direct + retry
# AZURE_OPENAI_KEY=
# AZURE_SEARCH_ENDPOINT=        # replaced by pgvector (commit 497df51)
# AZURE_SEARCH_KEY=
# SEARCH_INDEX_NAME=
# SEARCH_CHUNKS_INDEX_NAME=
# KEYVAULT_URL=                 # replaced by platform env vars (Railway secrets)
# SERVICE_BUS_NAMESPACE=        # replaced by Redis pub/sub + BackgroundTasks
# APPLICATIONINSIGHTS_CONNECTION_STRING=  # replaced by structlog → stdout
# ADLS_ACCOUNT_NAME=            # replaced by LocalStorageClient + persistent volume
# ADLS_ACCOUNT_KEY=
# ADLS_CONTAINER_NAME=
# ADLS_CONNECTION_STRING=
