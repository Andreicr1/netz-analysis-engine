{
  "name": "@investintell/ui",
  "version": "1.0.0",
  "type": "module",
  "description": "InvestIntell Design System — shadcn-svelte + Urbanist + analytical components",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./styles": "./src/lib/styles/globals.css",
    "./components/ui/*": {
      "types": "./dist/components/ui/*/index.d.ts",
      "svelte": "./dist/components/ui/*/index.js"
    },
    "./components/analytical/*": {
      "types": "./dist/components/analytical/*.svelte.d.ts",
      "svelte": "./dist/components/analytical/*.svelte"
    },
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "svelte": "./dist/charts/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "svelte": "./dist/runtime/index.js",
      "import": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./charts/echarts-setup": {
      "types": "./dist/charts/echarts-setup.d.ts",
      "svelte": "./dist/charts/echarts-setup.js",
      "import": "./dist/charts/echarts-setup.js",
      "default": "./dist/charts/echarts-setup.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "dev": "svelte-package -w",
    "build": "svelte-kit sync && svelte-package -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json && pnpm run check:tokens",
    "check:tokens": "node ../../scripts/check-terminal-tokens-sync.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/merge": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "codemirror-json-schema": "^0.8.0"
  },
  "peerDependenciesMeta": {
    "@codemirror/commands": { "optional": true },
    "@codemirror/lang-json": { "optional": true },
    "@codemirror/lint": { "optional": true },
    "@codemirror/merge": { "optional": true },
    "@codemirror/state": { "optional": true },
    "@codemirror/view": { "optional": true },
    "codemirror-json-schema": { "optional": true }
  },
  "dependencies": {
    "@fontsource-variable/urbanist": "^5.0.0",
    "@fontsource-variable/geist-mono": "^5.0.0",
    "@fontsource/ibm-plex-mono": "^5.0.0",
    "@fontsource/ibm-plex-sans": "^5.0.0",
    "@internationalized/date": "^3.12.0",
    "@tanstack/table-core": "^8.21.3",
    "bits-ui": "^2.16.4",
    "clsx": "^2.1.0",
    "echarts": "^5.6.0",
    "embla-carousel-svelte": "^8.6.0",
    "esm-env": "^1.0.0",
    "formsnap": "^2.0.1",
    "jose": "^5.0.0",
    "layerchart": "2.0.0-next.43",
    "mode-watcher": "^1.1.0",
    "lucide-svelte": "^0.469.0",
    "paneforge": "^1.0.2",
    "svelte-sonner": "^1.1.0",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^2.6.0",
    "tailwind-variants": "^3.2.2",
    "vaul-svelte": "1.0.0-next.7"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tanstack/svelte-table": "^9.0.0-alpha.10",
    "@tanstack/svelte-virtual": "^3.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.0.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^25.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
