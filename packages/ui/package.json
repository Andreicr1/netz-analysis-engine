{
  "name": "@netz/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Netz Analysis Engine — shared design system",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./styles": "./src/lib/styles/index.css",
    "./investintell-theme": "./src/lib/styles/investintell-theme.css",
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "svelte": "./dist/charts/index.js"
    },
    "./charts/echarts-setup": {
      "types": "./dist/charts/echarts-setup.d.ts",
      "svelte": "./dist/charts/echarts-setup.js",
      "import": "./dist/charts/echarts-setup.js",
      "default": "./dist/charts/echarts-setup.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "dev": "svelte-package -w",
    "build": "svelte-kit sync && svelte-package -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "svelte": "^5.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/merge": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "codemirror-json-schema": "^0.8.0"
  },
  "peerDependenciesMeta": {
    "@codemirror/commands": { "optional": true },
    "@codemirror/lang-json": { "optional": true },
    "@codemirror/lint": { "optional": true },
    "@codemirror/merge": { "optional": true },
    "@codemirror/state": { "optional": true },
    "@codemirror/view": { "optional": true },
    "codemirror-json-schema": { "optional": true }
  },
  "dependencies": {
    "@fontsource/geist": "^5.2.8",
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "bits-ui": "^1.0.0",
    "clsx": "^2.1.0",
    "echarts": "^5.6.0",
    "esm-env": "^1.0.0",
    "jose": "^5.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tanstack/svelte-table": "^9.0.0-alpha.10",
    "@tanstack/svelte-virtual": "^3.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.0.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^25.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
