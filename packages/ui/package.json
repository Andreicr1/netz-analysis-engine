{
  "name": "@netz/ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Netz Analysis Engine — shared design system",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./styles": "./src/lib/styles/index.css",
    "./charts": {
      "types": "./dist/charts/index.d.ts",
      "svelte": "./dist/charts/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    }
  },
  "scripts": {
    "dev": "svelte-package -w",
    "build": "svelte-kit sync && svelte-package -o dist",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "bits-ui": "^1.0.0",
    "clsx": "^2.1.0",
    "echarts": "^5.6.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tanstack/svelte-table": "^8.21.0",
    "@tanstack/svelte-virtual": "^3.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.0.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^25.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
