{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"strict": true,
		"moduleResolution": "bundler",
		"target": "ES2022",
		"module": "ES2022",
		"verbatimModuleSyntax": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true
	},
	"exclude": [
		"node_modules",
		"../../backend",
		"../../docs",
		"../../profiles",
		"../../calibration",
		"../../frontends/credit",
		"../../frontends/wealth"
	]
}
